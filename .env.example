# H98 Miner Config — safe to commit. Copy to .env, fill in real values.

# Required: wallet address (0x + 40 hex chars)
WALLET=0xYOUR_WALLET_ADDRESS_HERE

# Required: private key for on-chain submission (64 hex chars with 0x prefix)
PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY_HERE

# RPC endpoint (default: public node; replace with Alchemy/Infura for better performance)
RPC_URL=https://ethereum-rpc.publicnode.com

# CPU worker threads (default = num_cpus - 1)
# MINER_THREADS=8
