# Template config — aman di-commit. Copy ke .env, isi nilai asli.

# Required: 64 hex char (with or without 0x prefix)
PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY_HERE

# RPC endpoint (publik default; ganti ke Alchemy/Infura/punyamu kalau bisa)
RPC_URL=https://eth.llamarpc.com

# CPU worker threads (default = num_cpus - 1)
MINER_THREADS=8

# --- GPU (OpenCL) backend, optional ---
# Set GPU=1 untuk hidupin. Binary harus di-build dengan default feature `gpu`.
GPU=0

# Nonce per GPU dispatch. Default 4194304 (1 << 22). Naikkan kalau VRAM cukup.
# GPU_BATCH=4194304

# --- EIP-1559 gas tuning, optional ---
# PRIORITY_GWEI=5.0
# MAX_FEE_GWEI=100.0
# GAS_LIMIT_OVERRIDE=300000
